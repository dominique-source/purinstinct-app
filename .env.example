# ── Firebase (Vite exige le préfixe VITE_) ──────────────────────
# Console Firebase > Paramètres du projet > Tes applications > Config
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_DATABASE_URL=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# ── PINs d'accès (plus jamais dans le code source) ──────────────
# VITE_MODE_PIN retiré: remplacé par les codes VITE_CODE_* + resolveMode
# (étape 2 du multi-mode). ADMIN_PIN reste le raccourci "tout débloqué",
# STATION_PIN gate le rôle admin/station à l'intérieur du flux Live.
VITE_ADMIN_PIN=1111
VITE_STATION_PIN=2222

# ── Codes d'entrée multi-mode (src/config/modes.js) ──────────────
# Un code à 4 chiffres par mode (même pavé que les PINs ci-dessus) →
# resolveMode(code) mappe vers la clé de mode.
# Le code ADMIN_PIN ci-dessus reste le raccourci caché "tout débloqué".
VITE_CODE_GAMES=0000
VITE_CODE_CORPORATE=0001
VITE_CODE_ECOLE=0002
VITE_CODE_FESTIVAL=0003
VITE_CODE_PARC=0004
