{
  "rules": {
    ".read": false,
    ".write": false,

    "state": {
      ".read": "auth != null",
      ".write": "auth != null",

      "meta": {
        "lastPlayerId": { ".validate": "newData.isNumber()" }
      },

      "winnersPublished": { ".validate": "newData.isBoolean()" },
      "liveMode":         { ".validate": "newData.isBoolean()" },
      "activeRosterId":   { ".validate": "newData.isString()" },
      "activationMode":   { ".validate": "newData.isString()" },

      "players": {
        "$playerId": {
          "email":     { ".validate": "root.child('state/activationMode').val() !== 'ecole' || newData.val() === ''" },
          "instagram": { ".validate": "root.child('state/activationMode').val() !== 'ecole' || newData.val() === ''" },
          "tiktok":    { ".validate": "root.child('state/activationMode').val() !== 'ecole' || newData.val() === ''" },
          "snapchat":  { ".validate": "root.child('state/activationMode').val() !== 'ecole' || newData.val() === ''" }
        }
      },

      "teams": {
        "$zone": {
          "$teamId": {
            "name": { ".validate": "newData.isString()" },
            "memberIds": {
              "$index": { ".validate": "newData.isNumber()" }
            }
          }
        }
      },

      "teamPairCounts": {
        "$zone": {
          "$pairKey": { ".validate": "newData.isNumber()" }
        }
      }
    }
  }
}
